# ─── DukePulse Configuration ───────────────────────────────

# Telegram Bot (crear nuevo bot en @BotFather para DukePulse)
TELEGRAM_TOKEN=your_dukepulse_bot_token_here
ADMIN_USER_ID=your_telegram_user_id

# Webhook para N8N
WEBHOOK_SECRET=duke-secret-key-2024
WEBHOOK_PORT=8080

# Meta Graph API (mismo que PostFlow AI)
FACEBOOK_PAGE_ID=your_fb_page_id
FACEBOOK_PAGE_TOKEN=your_fb_page_token
INSTAGRAM_ACCOUNT_ID=your_ig_account_id

# IA (mismo que PostFlow AI)
ANTHROPIC_API_KEY=sk-ant-...

# Opcional: OpenAI como fallback
OPENAI_API_KEY=sk-...
